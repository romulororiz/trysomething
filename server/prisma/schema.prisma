// TrySomething — Prisma Schema
// Phase 1: Content models (10 tables)
// Phase 2: Auth models (User, UserPreference)
// Future phases add: Progress, Social, Gamification models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
//  CONTENT MODELS (Phase 1)
// ═══════════════════════════════════════════════════

model Category {
  id       String  @id
  name     String
  imageUrl String
  sortOrder Int    @default(0)
  hobbies  Hobby[]
}

model Hobby {
  id                String   @id
  title             String
  hook              String
  categoryId        String
  imageUrl          String
  tags              String[]
  costText          String
  timeText          String
  difficultyText    String
  whyLove           String
  difficultyExplain String
  pitfalls          String[]
  sortOrder         Int      @default(0)

  category       Category            @relation(fields: [categoryId], references: [id])
  kitItems       KitItem[]
  roadmapSteps   RoadmapStep[]
  faqItems       FaqItem[]
  costBreakdown  CostBreakdown?
  budgetAlts     BudgetAlternative[]
  combosAsFirst  HobbyCombo[]        @relation("comboHobbyA")
  combosAsSecond HobbyCombo[]        @relation("comboHobbyB")
  seasonalPicks  SeasonalPick[]
  moodTags       MoodTag[]
}

model KitItem {
  id          String  @id @default(cuid())
  hobbyId     String
  name        String
  description String
  cost        Int
  isOptional  Boolean @default(false)
  sortOrder   Int     @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model RoadmapStep {
  id               String  @id
  hobbyId          String
  title            String
  description      String
  estimatedMinutes Int
  milestone        String?
  sortOrder        Int     @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model FaqItem {
  id       String @id @default(cuid())
  hobbyId  String
  question String
  answer   String
  upvotes  Int    @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model CostBreakdown {
  id         String   @id @default(cuid())
  hobbyId    String   @unique
  starter    Int
  threeMonth Int
  oneYear    Int
  tips       String[]

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model BudgetAlternative {
  id            String @id @default(cuid())
  hobbyId       String
  itemName      String
  diyOption     String
  diyCost       Int
  budgetOption  String
  budgetCost    Int
  premiumOption String
  premiumCost   Int
  sortOrder     Int    @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model HobbyCombo {
  id         String   @id @default(cuid())
  hobbyId1   String
  hobbyId2   String
  reason     String
  sharedTags String[]

  hobbyA Hobby @relation("comboHobbyA", fields: [hobbyId1], references: [id], onDelete: Cascade)
  hobbyB Hobby @relation("comboHobbyB", fields: [hobbyId2], references: [id], onDelete: Cascade)

  @@unique([hobbyId1, hobbyId2])
}

model SeasonalPick {
  id       String @id @default(cuid())
  hobbyId  String
  season   String

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, season])
}

model MoodTag {
  id      String @id @default(cuid())
  hobbyId String
  mood    String

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, mood])
}

// ═══════════════════════════════════════════════════
//  AUTH MODELS (Phase 2)
// ═══════════════════════════════════════════════════

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  googleId     String?         @unique
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  preferences    UserPreference?
  hobbies        UserHobby[]
  activityLogs   UserActivityLog[]
  journalEntries JournalEntry[]
  personalNotes  PersonalNote[]
  scheduleEvents ScheduleEvent[]
  shoppingChecks ShoppingCheck[]
}

model UserPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  hoursPerWeek Int      @default(3)
  budgetLevel  Int      @default(1)
  preferSocial Boolean  @default(false)
  vibes        String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════
//  USER PROGRESS MODELS (Phase 3)
// ═══════════════════════════════════════════════════

enum HobbyStatus {
  saved
  trying
  active
  done
}

model UserHobby {
  id             String      @id @default(uuid())
  userId         String
  hobbyId        String
  status         HobbyStatus @default(saved)
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime?
  streakDays     Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedSteps UserCompletedStep[]

  @@unique([userId, hobbyId])
}

model UserCompletedStep {
  id          String   @id @default(uuid())
  userId      String
  hobbyId     String
  stepId      String
  completedAt DateTime @default(now())

  userHobby   UserHobby @relation(fields: [userId, hobbyId], references: [userId, hobbyId], onDelete: Cascade)

  @@unique([userId, hobbyId, stepId])
}

model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String
  hobbyId   String?
  action    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════
//  PERSONAL TOOLS MODELS (Phase 5)
// ═══════════════════════════════════════════════════

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  hobbyId   String
  text      String
  photoUrl  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PersonalNote {
  id       String @id @default(uuid())
  userId   String
  hobbyId  String
  stepId   String
  text     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hobbyId, stepId])
}

model ScheduleEvent {
  id              String @id @default(uuid())
  userId          String
  hobbyId         String
  dayOfWeek       Int
  startTime       String
  durationMinutes Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShoppingCheck {
  id       String  @id @default(uuid())
  userId   String
  hobbyId  String
  itemName String
  checked  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hobbyId, itemName])
}
