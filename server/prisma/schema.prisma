// TrySomething — Prisma Schema
// Phase 1: Content models (10 tables)
// Phase 2: Auth models (User, UserPreference)
// Future phases add: Progress, Social, Gamification models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
//  CONTENT MODELS (Phase 1)
// ═══════════════════════════════════════════════════

model Category {
  id       String  @id
  name     String
  imageUrl String
  sortOrder Int    @default(0)
  hobbies  Hobby[]
}

model Hobby {
  id                String   @id
  title             String
  hook              String
  categoryId        String
  imageUrl          String
  tags              String[]
  costText          String
  timeText          String
  difficultyText    String
  whyLove           String
  difficultyExplain String
  pitfalls          String[]
  sortOrder         Int      @default(0)
  isAiGenerated     Boolean  @default(false)
  generatedBy       String?
  createdAt         DateTime @default(now())

  category       Category            @relation(fields: [categoryId], references: [id])
  kitItems       KitItem[]
  roadmapSteps   RoadmapStep[]
  faqItems       FaqItem[]
  costBreakdown  CostBreakdown?
  budgetAlts     BudgetAlternative[]
  combosAsFirst  HobbyCombo[]        @relation("comboHobbyA")
  combosAsSecond HobbyCombo[]        @relation("comboHobbyB")
  seasonalPicks  SeasonalPick[]
  moodTags       MoodTag[]
}

model KitItem {
  id              String  @id @default(cuid())
  hobbyId         String
  name            String
  description     String
  cost            Int
  isOptional      Boolean @default(false)
  sortOrder       Int     @default(0)
  imageUrl        String?
  affiliateUrl    String?
  affiliateSource String?

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model RoadmapStep {
  id                String  @id
  hobbyId           String
  title             String
  description       String
  estimatedMinutes  Int
  milestone         String?
  coachTip          String?
  completionMessage String?
  sortOrder         Int     @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model FaqItem {
  id           String @id @default(cuid())
  hobbyId      String
  question     String
  answer       String
  upvotes      Int    @default(0)
  helpfulCount Int    @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model CostBreakdown {
  id         String   @id @default(cuid())
  hobbyId    String   @unique
  starter    Int
  threeMonth Int
  oneYear    Int
  tips       String[]

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model BudgetAlternative {
  id            String @id @default(cuid())
  hobbyId       String
  itemName      String
  diyOption     String
  diyCost       Int
  budgetOption  String
  budgetCost    Int
  premiumOption String
  premiumCost   Int
  sortOrder     Int    @default(0)

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model HobbyCombo {
  id         String   @id @default(cuid())
  hobbyId1   String
  hobbyId2   String
  reason     String
  sharedTags String[]

  hobbyA Hobby @relation("comboHobbyA", fields: [hobbyId1], references: [id], onDelete: Cascade)
  hobbyB Hobby @relation("comboHobbyB", fields: [hobbyId2], references: [id], onDelete: Cascade)

  @@unique([hobbyId1, hobbyId2])
}

model SeasonalPick {
  id       String @id @default(cuid())
  hobbyId  String
  season   String

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, season])
}

model MoodTag {
  id      String @id @default(cuid())
  hobbyId String
  mood    String

  hobby Hobby @relation(fields: [hobbyId], references: [id], onDelete: Cascade)

  @@unique([hobbyId, mood])
}

// ═══════════════════════════════════════════════════
//  AUTH MODELS (Phase 2)
// ═══════════════════════════════════════════════════

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  displayName  String
  bio          String          @default("")
  avatarUrl    String?
  googleId     String?         @unique
  appleId      String?         @unique
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Subscription
  subscriptionTier   String    @default("free") // "free", "trial", "pro", "lifetime"
  proSince           DateTime?
  proExpiresAt       DateTime?
  isLifetime         Boolean   @default(false)
  revenuecatId       String?   @unique

  preferences    UserPreference?
  hobbies        UserHobby[]
  activityLogs   UserActivityLog[]
  journalEntries JournalEntry[]
  personalNotes  PersonalNote[]
  scheduleEvents ScheduleEvent[]
  shoppingChecks ShoppingCheck[]
  communityStories   CommunityStory[]
  storyReactions     StoryReaction[]
  buddyRequestsSent  BuddyPair[] @relation("buddyRequests")
  buddyRequestsRcvd  BuddyPair[] @relation("buddyAccepts")
  challenges         UserChallenge[]
  achievements       UserAchievement[]
}

model UserPreference {
  id           String   @id @default(uuid())
  userId       String   @unique
  hoursPerWeek Int      @default(3)
  budgetLevel  Int      @default(1)
  preferSocial Boolean  @default(false)
  vibes        String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════
//  USER PROGRESS MODELS (Phase 3)
// ═══════════════════════════════════════════════════

enum HobbyStatus {
  saved
  trying
  active
  paused
  done
}

model UserHobby {
  id             String      @id @default(uuid())
  userId         String
  hobbyId        String
  status         HobbyStatus @default(saved)
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime?
  streakDays          Int         @default(0)
  pausedAt            DateTime?
  pausedDurationDays  Int         @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedSteps UserCompletedStep[]

  @@unique([userId, hobbyId])
}

model UserCompletedStep {
  id          String   @id @default(uuid())
  userId      String
  hobbyId     String
  stepId      String
  completedAt DateTime @default(now())

  userHobby   UserHobby @relation(fields: [userId, hobbyId], references: [userId, hobbyId], onDelete: Cascade)

  @@unique([userId, hobbyId, stepId])
}

model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String
  hobbyId   String?
  action    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ═══════════════════════════════════════════════════
//  PERSONAL TOOLS MODELS (Phase 5)
// ═══════════════════════════════════════════════════

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  hobbyId   String
  text      String
  photoUrl  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PersonalNote {
  id       String @id @default(uuid())
  userId   String
  hobbyId  String
  stepId   String
  text     String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hobbyId, stepId])
}

model ScheduleEvent {
  id              String @id @default(uuid())
  userId          String
  hobbyId         String
  dayOfWeek       Int
  startTime       String
  durationMinutes Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShoppingCheck {
  id       String  @id @default(uuid())
  userId   String
  hobbyId  String
  itemName String
  checked  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hobbyId, itemName])
}

// ═══════════════════════════════════════════════════
//  SOCIAL MODELS (Phase 6)
// ═══════════════════════════════════════════════════

model CommunityStory {
  id        String   @id @default(uuid())
  userId    String
  quote     String
  hobbyId   String
  createdAt DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions StoryReaction[]

  @@index([createdAt])
}

model StoryReaction {
  id      String @id @default(uuid())
  userId  String
  storyId String
  type    String // "heart" or "fire"

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  story CommunityStory @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId, type])
}

model BuddyPair {
  id          String   @id @default(uuid())
  requesterId String
  accepterId  String
  hobbyId     String?
  status      String   @default("pending") // pending, active, rejected
  createdAt   DateTime @default(now())

  requester User @relation("buddyRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  accepter  User @relation("buddyAccepts", fields: [accepterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, accepterId])
  @@index([requesterId])
  @@index([accepterId])
}

// ═══════════════════════════════════════════════════
//  GAMIFICATION MODELS (Phase 7)
// ═══════════════════════════════════════════════════

model UserChallenge {
  id            String    @id @default(uuid())
  userId        String
  challengeType String    // try_new_hobby, complete_steps, journal_entry, share_story
  currentCount  Int       @default(0)
  targetCount   Int
  isCompleted   Boolean   @default(false)
  weekStart     DateTime  // Monday of the challenge week
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeType, weekStart])
  @@index([userId, weekStart])
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String   // matches server-side achievement definitions
  unlockedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ═══════════════════════════════════════════════════
//  AI GENERATION (Phase 9)
// ═══════════════════════════════════════════════════

model GenerationLog {
  id        String   @id @default(cuid())
  userId    String
  query     String
  hobbyId   String?
  status    String   // "success", "rejected", "error"
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
