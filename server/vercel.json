{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/cron/purge-deleted-users", "dest": "/api/users/[path].ts?path=purge-deleted-users" },
    { "src": "/api/users/me/export", "dest": "/api/users/[path].ts?path=export" },
    { "src": "/api/health", "dest": "/api/health.ts" },
    { "src": "/api/auth/(register|login|refresh|google|apple|apple-callback|verify-email|resend-verification|forgot-password|reset-password)", "dest": "/api/auth/[action].ts?action=$1" },
    { "src": "/api/users/hobbies-sync", "dest": "/api/users/[path].ts?path=hobbies-sync" },
    { "src": "/api/users/hobbies/([^/]+)/steps/([^/]+)", "dest": "/api/users/[path].ts?path=hobbies-detail&hobbyId=$1&stepId=$2" },
    { "src": "/api/users/hobbies/([^/]+)", "dest": "/api/users/[path].ts?path=hobbies-detail&hobbyId=$1" },
    { "src": "/api/users/hobbies", "dest": "/api/users/[path].ts?path=hobbies" },
    { "src": "/api/users/activity", "dest": "/api/users/[path].ts?path=activity" },
    { "src": "/api/users/journal/([^/]+)", "dest": "/api/users/[path].ts?path=journal-detail&entryId=$1" },
    { "src": "/api/users/journal", "dest": "/api/users/[path].ts?path=journal" },
    { "src": "/api/users/notes/([^/]+)/([^/]+)", "dest": "/api/users/[path].ts?path=notes&hobbyId=$1&stepId=$2" },
    { "src": "/api/users/notes/([^/]+)", "dest": "/api/users/[path].ts?path=notes&hobbyId=$1" },
    { "src": "/api/users/schedule/([^/]+)", "dest": "/api/users/[path].ts?path=schedule-detail&eventId=$1" },
    { "src": "/api/users/schedule", "dest": "/api/users/[path].ts?path=schedule" },
    { "src": "/api/users/shopping/([^/]+)", "dest": "/api/users/[path].ts?path=shopping&hobbyId=$1" },
    { "src": "/api/users/stories/([^/]+)/react/([^/]+)", "dest": "/api/users/[path].ts?path=stories-react&storyId=$1&type=$2" },
    { "src": "/api/users/stories/([^/]+)", "dest": "/api/users/[path].ts?path=stories-detail&storyId=$1" },
    { "src": "/api/users/stories", "dest": "/api/users/[path].ts?path=stories" },
    { "src": "/api/users/buddies", "dest": "/api/users/[path].ts?path=buddies" },
    { "src": "/api/users/buddy-requests/([^/]+)", "dest": "/api/users/[path].ts?path=buddy-requests-detail&requestId=$1" },
    { "src": "/api/users/buddy-requests", "dest": "/api/users/[path].ts?path=buddy-requests" },
    { "src": "/api/users/similar-users", "dest": "/api/users/[path].ts?path=similar-users" },
    { "src": "/api/users/challenges", "dest": "/api/users/[path].ts?path=challenges" },
    { "src": "/api/users/achievements", "dest": "/api/users/[path].ts?path=achievements" },
    { "src": "/api/users/(me|preferences)", "dest": "/api/users/[path].ts?path=$1" },
    { "src": "/api/webhooks/revenuecat", "dest": "/api/users/[path].ts?path=revenuecat-webhook" },
    { "src": "/api/generate/(hobby|faq|cost|budget|coach|moderate-image)", "dest": "/api/generate/[action].ts?action=$1" },
    { "src": "/api/categories", "dest": "/api/categories/index.ts" },
    { "src": "/api/hobbies/search", "dest": "/api/hobbies/search.ts" },
    { "src": "/api/hobbies/combos", "dest": "/api/hobbies/combos.ts" },
    { "src": "/api/hobbies/seasonal", "dest": "/api/hobbies/seasonal.ts" },
    { "src": "/api/hobbies/mood", "dest": "/api/hobbies/mood.ts" },
    { "src": "/api/hobbies/([^/]+)/faq/([^/]+)/vote", "dest": "/api/hobbies/[id]/[feature].ts?id=$1&feature=faq&faqId=$2" },
    { "src": "/api/hobbies/([^/]+)/(faq|cost|budget)", "dest": "/api/hobbies/[id]/[feature].ts?id=$1&feature=$2" },
    { "src": "/api/hobbies/([^/]+)", "dest": "/api/hobbies/[id]/index.ts?id=$1" },
    { "src": "/api/hobbies", "dest": "/api/hobbies/index.ts" }
  ],
  "crons": [
    {
      "path": "/api/cron/purge-deleted-users",
      "schedule": "0 3 * * *"
    }
  ]
}
